# Android release signing — local Android Studio template.
#
# Copy this file to ../keystore.properties (sibling of env.local.properties)
# and fill in the values from your `keytool`-generated upload keystore.
# The real file is gitignored; never commit secrets.
#
# CI uses the same fields exposed as GitHub Actions secrets:
#   ANDROID_KEYSTORE_BASE64   (base64 of the .jks file itself)
#   ANDROID_KEYSTORE_PASSWORD (== storePassword)
#   ANDROID_KEY_ALIAS         (== keyAlias)
#   ANDROID_KEY_PASSWORD      (== keyPassword)
#
# See android-native/RELEASE_GUIDE.md for the keytool command + the full
# Play Console first-deploy walkthrough.

# Absolute path to the .jks file. On Windows use forward slashes.
storeFile=C:/Users/yourname/keys/eatpal-release.jks

# Password protecting the keystore file (the one you typed twice when keytool ran).
storePassword=CHANGE_ME

# The alias you gave the key inside the keystore (e.g. "eatpal-upload").
keyAlias=eatpal-upload

# Password protecting that specific key. Often the same as storePassword.
keyPassword=CHANGE_ME
