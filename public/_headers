# Global headers for all pages
/*
  # Security headers
  # Clickjacking protection
  X-Frame-Options: DENY

  # MIME type sniffing protection
  X-Content-Type-Options: nosniff

  # XSS protection (disabled in favor of CSP per modern best practice)
  X-XSS-Protection: 0

  # Referrer policy (privacy)
  Referrer-Policy: strict-origin-when-cross-origin

  # Feature policy (privacy)
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=(), payment=(self), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), ambient-light-sensor=()

  # Cross-Origin policies
  Cross-Origin-Embedder-Policy: credentialless
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin

  # DNS prefetch control
  X-DNS-Prefetch-Control: on

  # Content Security Policy
  # 'unsafe-inline' required for Vite's injected styles and inline <script> tags in SSR/SPA
  # 'unsafe-eval' scoped to Three.js/shader compilation requirement (used on landing page only)
  # Cloudflare Pages does not support nonce-based CSP without Workers middleware
  # Self-hosted Supabase: api.tryeatpal.com, functions.tryeatpal.com
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com https://js.stripe.com https://*.tryeatpal.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: https: blob:; connect-src 'self' https://www.google-analytics.com https://api.tryeatpal.com https://functions.tryeatpal.com wss://api.tryeatpal.com https://api.stripe.com https://*.sentry.io; frame-src 'self' https://js.stripe.com https://hooks.stripe.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests; block-all-mixed-content;

  # Report CSP violations (for monitoring)
  # Content-Security-Policy-Report-Only: default-src 'self'; report-uri /api/csp-report;
  
  # Performance and caching
  Cache-Control: public, max-age=0, must-revalidate

  # CORS headers removed - not needed for same-origin SPA
  # Supabase handles CORS for its API endpoints
  # If you need CORS for specific routes, add them below with specific origins

# Static assets - long-term caching
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  
/images/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts - long-term caching
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Images - long-term caching for optimized assets
/assets/images/*
  Cache-Control: public, max-age=31536000, immutable
  
/*.webp
  Cache-Control: public, max-age=31536000, immutable
  
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
  
/*.jpeg
  Cache-Control: public, max-age=31536000, immutable
  
/*.png
  Cache-Control: public, max-age=31536000, immutable
  
/*.svg
  Cache-Control: public, max-age=31536000, immutable
  
/*.gif
  Cache-Control: public, max-age=31536000, immutable

# JavaScript and CSS - versioned assets
/assets/js/*
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/javascript; charset=utf-8
  
/assets/css/*
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: text/css; charset=utf-8

# API routes - no caching
/api/*
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Sitemap files - moderate caching
/sitemap*.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/xml; charset=utf-8

# Robots.txt - moderate caching
/robots.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8

# LLM information files - moderate caching
/llms.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8
  X-Robots-Tag: noindex

/llms-full.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8
  X-Robots-Tag: noindex

# RSS and Atom feeds
/rss.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/rss+xml; charset=utf-8

/feed.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/atom+xml; charset=utf-8

# Manifest files
/manifest.json
  Cache-Control: public, max-age=3600
  Content-Type: application/json; charset=utf-8
  
/.well-known/*
  Cache-Control: public, max-age=3600

# Favicon files - UPDATED: force cache refresh for new favicon
/favicon.ico
  Cache-Control: public, max-age=86400, must-revalidate
  
/favicon*.png
  Cache-Control: public, max-age=86400, must-revalidate
  
/apple-touch-icon*.png
  Cache-Control: public, max-age=86400, must-revalidate

/android-chrome*.png
  Cache-Control: public, max-age=86400, must-revalidate

# Service worker
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# HTML files - short caching for SPA
/*.html
  Cache-Control: public, max-age=300
  Content-Type: text/html; charset=utf-8

# Security headers for admin routes
/admin/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-cache, no-store, must-revalidate

# SEO optimization headers
/blog/*
  Cache-Control: public, max-age=3600
  
# Preload critical resources
/
  Link: </Logo-Green.webp>; rel=preload; as=image; type=image/webp
  
# HSTS for security
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

